# ===========================================
# Variáveis de Ambiente - Agente IA RV (Stevan)
# ===========================================
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o arquivo .env!

# --- Ambiente ---
ENV=development
# Em produção: ENV=production

# --- URL Pública da Aplicação ---
APP_BASE_URL=http://localhost:5000
# Em produção: APP_BASE_URL=https://seu-dominio.up.railway.app

# --- Segurança ---
SESSION_SECRET=gere-uma-chave-segura-aqui
ALLOWED_ORIGINS=http://localhost:5000
# Em produção: ALLOWED_ORIGINS=https://seu-dominio.up.railway.app

# --- Banco de Dados ---
DATABASE_URL=postgresql://usuario:senha@host:porta/banco
# Requer PostgreSQL com extensão pgvector instalada

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-...

# --- SSO Microsoft (Azure AD) ---
MICROSOFT_CLIENT_ID=seu-client-id
MICROSOFT_CLIENT_SECRET=seu-client-secret
MICROSOFT_TENANT_ID=seu-tenant-id

# --- Z-API (WhatsApp) ---
ZAPI_INSTANCE_ID=sua-instance-id
ZAPI_TOKEN=seu-token
ZAPI_CLIENT_TOKEN=seu-client-token

# --- Tavily (Web Search) ---
TAVILY_API_KEY=tvly-...
