modules = ["python-3.11", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["cargo", "glibcLocales", "libiconv", "libxcrypt", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Application"

[[workflows.workflow]]
name = "Start Application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python", "main.py"]

[userenv]

[userenv.shared]
WAHA_API_URL = "https://waha-production-3000.up.railway.app"
OPENAI_ORG_ID = "org-ea0pS41q43zJPgCzWLoUnGzi"
OPENAI_PROJECT_ID = "proj_ESHVQ6hdk1CDKTUaNSE9WpWU"
WAHA_SESSION = "default"
